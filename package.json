{
  "name": "cyntro-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "node -e \"const pkg=require('./package.json'); const v=pkg.dependencies.next; if(!v.startsWith('16.1')) { console.error('ERROR: Next.js must be 16.1.x for security patch'); process.exit(1); }\"",
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/integration/damage-scope-handoff-live.spec.ts tests/integration/damage-aware-path-card-live.spec.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:ir-purity": "scripts/check_ir_purity.sh",
    "verify-next": "node -e \"const pkg=require('./package.json'); console.log('Next.js version:', pkg.dependencies.next); if(!pkg.dependencies.next.startsWith('16.1')) { console.error('ERROR: Next.js must be 16.1.x'); process.exit(1); } else { console.log('✅ Next.js version is secure'); }\""
  },
